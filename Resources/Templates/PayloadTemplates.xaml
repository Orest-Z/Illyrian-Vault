<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:helpers="clr-namespace:IllyrianVault.Helpers">

    <!-- ══════════════════════ LOGIN ══════════════════════ -->

    <DataTemplate x:Key="LoginViewTemplate">
        <StackPanel>
            <!-- Username -->
            <TextBlock Text="{DynamicResource FieldUsername}" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Username}"
                           Foreground="{DynamicResource BrushText}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="{StaticResource FontInput}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1" Style="{StaticResource BtnIconSmall}"
                        Command="{Binding DataContext.CopyUsernameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Copy username">
                    <iconPacks:PackIconMaterial Kind="ContentCopy" Width="13" Height="13"/>
                </Button>
            </Grid>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <!-- Password -->
            <TextBlock Text="{DynamicResource FieldPassword}" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding DataContext.SelectedEntry.DisplayPassword, RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="{DynamicResource BrushText}"
                           FontFamily="{StaticResource FontMono}"
                           FontSize="{StaticResource FontInput}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1" Style="{StaticResource BtnIconSmall}"
                        Command="{Binding DataContext.TogglePasswordRevealCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Show / hide password">
                    <iconPacks:PackIconMaterial Kind="Eye" Width="13" Height="13"/>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource BtnIconSmall}"
                        Command="{Binding DataContext.CopyPasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Copy password">
                    <iconPacks:PackIconMaterial Kind="ContentCopy" Width="13" Height="13"/>
                </Button>
            </Grid>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <!-- Website -->
            <TextBlock Text="{DynamicResource FieldWebsite}" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Url}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontInput}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,8,0,0"/>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <!-- Notes -->
            <TextBlock Text="{DynamicResource FieldNotes}" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Notes}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="LoginEditTemplate">
        <StackPanel>
            <!-- Username -->
            <TextBlock Text="{DynamicResource FieldUsername}" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,16"/>

            <!-- Password -->
            <TextBlock Text="{DynamicResource FieldPassword}" Style="{StaticResource FieldLabel}"/>
            <PasswordBox Style="{StaticResource PasswordInput}"
                         helpers:PasswordBoxHelper.BindPassword="True"
                         helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}"
                         Margin="0,8,0,16"/>

            <!-- Website -->
            <TextBlock Text="{DynamicResource FieldWebsite}" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,16"/>

            <!-- Notes -->
            <TextBlock Text="{DynamicResource FieldNotes}" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="72"
                     VerticalContentAlignment="Top"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,8,0,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- ══════════════════════ NOTE ══════════════════════ -->

    <DataTemplate x:Key="NoteViewTemplate">
        <StackPanel>
            <TextBlock Text="{DynamicResource FieldNotes}" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Content}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="NoteEditTemplate">
        <StackPanel>
            <TextBlock Text="{DynamicResource FieldNotes}" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="120"
                     VerticalContentAlignment="Top"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,8,0,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- ══════════════════════ CARD ══════════════════════ -->

    <DataTemplate x:Key="CardViewTemplate">
        <StackPanel>
            <!-- Cardholder Name -->
            <TextBlock Text="Cardholder Name" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding CardholderName}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontInput}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,8,0,0"/>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <!-- Card Number -->
            <TextBlock Text="Card Number" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding CardNumber}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontMono}"
                       FontSize="{StaticResource FontInput}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,8,0,0"/>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <!-- Expiry -->
            <TextBlock Text="Expiry (MM/YY)" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Expiry}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontMono}"
                       FontSize="{StaticResource FontInput}"
                       Margin="0,8,0,0"/>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <!-- CVV (always masked in view mode) -->
            <TextBlock Text="CVV" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="•••"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontMono}"
                       FontSize="{StaticResource FontInput}"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="CardEditTemplate">
        <StackPanel>
            <TextBlock Text="Cardholder Name" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding CardholderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,16"/>

            <TextBlock Text="Card Number" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding CardNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="{StaticResource FontMono}"
                     Margin="0,8,0,16"/>

            <TextBlock Text="Expiry (MM/YY)" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Expiry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,16"/>

            <TextBlock Text="CVV" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Cvv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- ══════════════════════ IDENTITY ══════════════════════ -->

    <DataTemplate x:Key="IdentityViewTemplate">
        <StackPanel>
            <TextBlock Text="Full Name" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding FullName}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontInput}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,8,0,0"/>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Email}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontInput}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,8,0,0"/>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Phone}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontInput}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,8,0,0"/>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <TextBlock Text="Birthdate" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Birthdate}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontInput}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,8,0,0"/>

            <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,16"/>

            <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{Binding Address}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="IdentityEditTemplate">
        <StackPanel>
            <TextBlock Text="Full Name" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,16"/>

            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,16"/>

            <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,16"/>

            <TextBlock Text="Birthdate" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Birthdate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,8,0,16"/>

            <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"
                     VerticalContentAlignment="Top"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,8,0,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- ══════════════════════ SELECTORS ══════════════════════ -->

    <helpers:PayloadViewSelector x:Key="PayloadViewSelector"
                                 LoginTemplate="{StaticResource LoginViewTemplate}"
                                 NoteTemplate="{StaticResource NoteViewTemplate}"
                                 CardTemplate="{StaticResource CardViewTemplate}"
                                 IdentityTemplate="{StaticResource IdentityViewTemplate}"/>

    <helpers:PayloadEditSelector x:Key="PayloadEditSelector"
                                 LoginTemplate="{StaticResource LoginEditTemplate}"
                                 NoteTemplate="{StaticResource NoteEditTemplate}"
                                 CardTemplate="{StaticResource CardEditTemplate}"
                                 IdentityTemplate="{StaticResource IdentityEditTemplate}"/>

</ResourceDictionary>
