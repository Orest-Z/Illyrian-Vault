<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark — slate/navy + indigo accent -->

    <LinearGradientBrush x:Key="BrushWindowGrad" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#16161A" Offset="0"/>
        <GradientStop Color="#1A1A22" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="BrushWindow"        Color="#16161A"/>
    <SolidColorBrush x:Key="BrushSidebar"       Color="#1B1B20"/>
    <SolidColorBrush x:Key="BrushCard"          Color="#22222A"/>
    <SolidColorBrush x:Key="BrushElevated"      Color="#2A2A33"/>
    <SolidColorBrush x:Key="BrushHover"         Color="#2E2E3A"/>
    <SolidColorBrush x:Key="BrushSelected"      Color="#2C2D4A"/>

    <SolidColorBrush x:Key="BrushStrokeSubtle"  Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="BrushStroke"        Color="#2EFFFFFF"/>
    <SolidColorBrush x:Key="BrushStrokeStrong"  Color="#52FFFFFF"/>

    <SolidColorBrush x:Key="BrushText"          Color="#F2F2F7"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#A0A0AE"/>
    <SolidColorBrush x:Key="BrushTextTertiary"  Color="#6D6D7C"/>

    <Color  x:Key="ColorAccent"                 >#6366F1</Color>
    <SolidColorBrush x:Key="BrushAccent"        Color="#6366F1"/>
    <SolidColorBrush x:Key="BrushAccentHover"   Color="#818CF8"/>
    <SolidColorBrush x:Key="BrushAccentPress"   Color="#4F52D6"/>
    <!-- rgba(99,102,241,0.20) → alpha 0x33 -->
    <SolidColorBrush x:Key="BrushAccentSoft"    Color="#336366F1"/>
    <SolidColorBrush x:Key="BrushOnAccent"      Color="#FFFFFF"/>

    <SolidColorBrush x:Key="BrushSuccess"       Color="#10B981"/>
    <SolidColorBrush x:Key="BrushWarning"       Color="#F59E0B"/>
    <SolidColorBrush x:Key="BrushDanger"        Color="#EF4444"/>
    <SolidColorBrush x:Key="BrushSuccessSoft"   Color="#3310B981"/>
    <SolidColorBrush x:Key="BrushWarningSoft"   Color="#33F59E0B"/>

</ResourceDictionary>
