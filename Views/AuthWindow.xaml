<Window x:Class="IllyriaVault.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IllyriaVault.ViewModels"
        xmlns:views="clr-namespace:IllyriaVault.Views"
        Title="Illyria Vault"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="1000" Height="680">

    <Window.Resources>
        <!-- ViewModel → View mapping for the ContentControl below -->
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <views:RegisterView/>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer margin leaves room for the drop-shadow effect -->
    <Border Margin="20"
            Background="{DynamicResource BrushWindowGrad}"
            BorderBrush="{DynamicResource BrushStrokeSubtle}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="12"
                              Opacity="0.55" Direction="270"/>
        </Border.Effect>

        <!-- CurrentViewModel is set by AuthWindow.xaml.cs -->
        <ContentControl Content="{Binding CurrentViewModel}"/>
    </Border>
</Window>
