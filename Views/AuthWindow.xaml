<Window x:Class="IllyriaVault.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:vm="clr-namespace:IllyriaVault.ViewModels"
        xmlns:views="clr-namespace:IllyriaVault.Views"
        Title="Illyria Vault"
        Icon="/IllyriaVault.png"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Width="1000" Height="680"
        MinWidth="700" MinHeight="500">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <views:RegisterView/>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="OuterBorder"
            Margin="20"
            Background="{DynamicResource BrushWindowGrad}"
            BorderBrush="{DynamicResource BrushStrokeSubtle}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="12"
                              Opacity="0.55" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ─────────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Brand -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="22" Height="22" CornerRadius="6"
                                Background="{DynamicResource BrushAccent}">
                            <iconPacks:PackIconMaterial Kind="ShieldLock" Width="12" Height="12"
                                                        Foreground="{DynamicResource BrushOnAccent}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Illyria Vault"
                                   Foreground="{DynamicResource BrushText}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="{StaticResource FontBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <Border Width="1" Height="14"
                                Background="{DynamicResource BrushStroke}"
                                Margin="14,0"/>
                        <TextBlock Text="{DynamicResource EncryptionLabel}"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource BtnWinControl}" Click="MinimizeClick">
                            <iconPacks:PackIconMaterial Kind="Minus" Width="12" Height="12"/>
                        </Button>
                        <Button Style="{StaticResource BtnWinControl}" Click="MaximizeClick">
                            <iconPacks:PackIconMaterial x:Name="MaximizeIcon" Kind="Fullscreen" Width="11" Height="11"/>
                        </Button>
                        <Button Style="{StaticResource BtnClose}" Click="CloseClick">
                            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Content (Login or Register view swapped via DataTemplate) ── -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Border>
</Window>
