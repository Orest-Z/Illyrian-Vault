<UserControl x:Class="IllyriaVault.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:IllyriaVault.Helpers"
             xmlns:conv="clr-namespace:IllyriaVault.Converters">

    <UserControl.Resources>
        <conv:PasswordStrengthToBrushConverter x:Key="StrengthBrush"/>
        <conv:PasswordStrengthToBarConverter   x:Key="StrengthBar"/>
    </UserControl.Resources>

    <!-- PHASE 1 STUB — replaced with full 3-step wizard in Phase 2 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="Transparent">
            <TextBlock Text="Illyria Vault — Setup"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontBody}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="16,0"/>
        </Border>

        <!-- Step content -->
        <StackPanel Grid.Row="1"
                    Width="440"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Step label -->
            <TextBlock Text="{Binding StepLabel}"
                       Foreground="{DynamicResource BrushAccent}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontLabel}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <!-- Progress bars (3 segments) -->
            <UniformGrid Rows="1" Columns="3" Height="4" Margin="0,0,0,24">
                <Rectangle Fill="{DynamicResource BrushAccent}" RadiusX="2" RadiusY="2" Margin="0,0,3,0"/>
                <Rectangle Margin="3,0">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding CurrentStep, Converter={StaticResource StrengthBar}, ConverterParameter=2}"/>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Margin="3,0,0,0">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding CurrentStep, Converter={StaticResource StrengthBar}, ConverterParameter=3}"/>
                    </Rectangle.Fill>
                </Rectangle>
            </UniformGrid>

            <!-- Step 1: Username + New password -->
            <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{DynamicResource SetupTitle}"
                           Foreground="{DynamicResource BrushText}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="{StaticResource FontCardHead}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <TextBlock Text="{DynamicResource Username}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="{DynamicResource NewPassword}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                <PasswordBox Style="{StaticResource PasswordInput}"
                             helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay}"
                             Margin="0,0,0,16"/>

                <TextBlock Text="{DynamicResource ConfirmPassword}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                <PasswordBox Style="{StaticResource PasswordInput}"
                             helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                             Margin="0,0,0,16"/>

                <!-- Strength indicator -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource PasswordStrength}" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StrengthLabel}"
                               Foreground="{Binding StrengthScore, Converter={StaticResource StrengthBrush}}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSmall}"
                               FontWeight="SemiBold"/>
                </Grid>
                <UniformGrid Rows="1" Columns="5" Height="4" Margin="0,8,0,12">
                    <Rectangle Fill="{Binding StrengthScore, Converter={StaticResource StrengthBar}, ConverterParameter=1}" RadiusX="2" RadiusY="2" Margin="0,0,3,0"/>
                    <Rectangle Fill="{Binding StrengthScore, Converter={StaticResource StrengthBar}, ConverterParameter=2}" RadiusX="2" RadiusY="2" Margin="3,0"/>
                    <Rectangle Fill="{Binding StrengthScore, Converter={StaticResource StrengthBar}, ConverterParameter=3}" RadiusX="2" RadiusY="2" Margin="3,0"/>
                    <Rectangle Fill="{Binding StrengthScore, Converter={StaticResource StrengthBar}, ConverterParameter=4}" RadiusX="2" RadiusY="2" Margin="3,0"/>
                    <Rectangle Fill="{Binding StrengthScore, Converter={StaticResource StrengthBar}, ConverterParameter=5}" RadiusX="2" RadiusY="2" Margin="3,0,0,0"/>
                </UniformGrid>
                <TextBlock Text="{DynamicResource PasswordHint}"
                           Foreground="{DynamicResource BrushTextTertiary}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="{StaticResource FontSmall}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Step 2: Recovery key -->
            <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{DynamicResource BackupKey}"
                           Foreground="{DynamicResource BrushText}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="{StaticResource FontCardHead}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <TextBlock Text="{Binding RecoveryKey}"
                               Foreground="{DynamicResource BrushText}"
                               FontFamily="{StaticResource FontMono}"
                               FontSize="{StaticResource FontBody}"
                               TextWrapping="Wrap"/>
                </Border>

                <Button Content="{DynamicResource DownloadKey}"
                        Style="{StaticResource BtnSecondary}"
                        Command="{Binding DownloadKeyCommand}"
                        Margin="0,0,0,16"/>

                <CheckBox Content="{DynamicResource KeySaved}"
                          Style="{StaticResource VaultCheckBox}"
                          IsChecked="{Binding IsKeySaved, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Step 3: Confirm -->
            <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource AlmostThere}"
                           Foreground="{DynamicResource BrushText}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="{StaticResource FontCardHead}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource AlmostSub}"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="{StaticResource FontBody}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource BrushDanger}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontSmall}"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- Footer buttons -->
        <Grid Grid.Row="2" Margin="64,0,64,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Style="{StaticResource BtnSecondary}"
                    Command="{Binding BackCommand}"
                    Margin="0,0,8,0">
                <Button.Content>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{DynamicResource BackButton}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                        <Setter Property="Text" Value="{DynamicResource BtnCancel}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button.Content>
            </Button>
            <Button Grid.Column="1"
                    Style="{StaticResource BtnPrimary}"
                    Command="{Binding NextCommand}"
                    Margin="8,0,0,0">
                <Button.Content>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{DynamicResource ContinueButton}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                        <Setter Property="Text" Value="{DynamicResource CreateMyVault}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</UserControl>
