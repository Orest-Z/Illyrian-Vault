<UserControl x:Class="IllyrianVault.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:helpers="clr-namespace:IllyrianVault.Helpers">

    <!-- 2-column body: left hero + right form (matches HTML .login-body layout) -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="440"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left hero panel ─────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="{DynamicResource BrushCard}"
                BorderBrush="{DynamicResource BrushStrokeSubtle}"
                BorderThickness="1"
                CornerRadius="16"
                Margin="8,8,12,24"
                Padding="48">
            <Border.Effect>
                <!-- Radial accent glow (HTML .login-hero::before) -->
                <DropShadowEffect Color="{DynamicResource ColorAccent}" BlurRadius="80" ShadowDepth="0" Opacity="0.12" Direction="45"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <!-- Shield mark -->
                <Border Width="56" Height="56" CornerRadius="14"
                        Background="{DynamicResource BrushAccent}">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ColorAccent}" BlurRadius="36" ShadowDepth="0" Opacity="0.55"/>
                    </Border.Effect>
                    <iconPacks:PackIconMaterial Kind="ShieldLock"
                                               Width="26" Height="26"
                                               Foreground="{DynamicResource BrushOnAccent}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                </Border>

                <!-- App name -->
                <TextBlock Text="{DynamicResource AppName}"
                           Foreground="{DynamicResource BrushText}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="34"
                           FontWeight="SemiBold"
                           Margin="0,24,0,8"
                           LineHeight="37"/>
                <TextBlock Text="{DynamicResource AppTagline}"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="14"/>

                <!-- Feature list -->
                <StackPanel Margin="0,32,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="{DynamicResource BrushAccentSoft}">
                            <iconPacks:PackIconMaterial Kind="Lock" Width="14" Height="14"
                                                        Foreground="{DynamicResource BrushAccent}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="AES-256 encrypted vault"
                                   Foreground="{DynamicResource BrushText}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="{DynamicResource BrushAccentSoft}">
                            <iconPacks:PackIconMaterial Kind="CloudOffOutline" Width="14" Height="14"
                                                        Foreground="{DynamicResource BrushAccent}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="100% offline — no cloud sync"
                                   Foreground="{DynamicResource BrushText}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="{DynamicResource BrushAccentSoft}">
                            <iconPacks:PackIconMaterial Kind="ShieldKey" Width="14" Height="14"
                                                        Foreground="{DynamicResource BrushAccent}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="PBKDF2 · 600 000 iterations"
                                   Foreground="{DynamicResource BrushText}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Right form panel ────────────────────────────────────────────── -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,8,40,24">
        <StackPanel VerticalAlignment="Center">

            <!-- Title + subtitle -->
            <TextBlock Text="{DynamicResource LoginWelcome}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontCardHead}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>
            <TextBlock Text="{DynamicResource LoginSubtitle}"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontBody}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,28"/>

            <!-- Profile chip -->
            <Border Background="{DynamicResource BrushElevated}"
                    BorderBrush="{DynamicResource BrushStroke}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12,10"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="32" Height="32" CornerRadius="16"
                            Background="{DynamicResource BrushAccent}">
                        <TextBlock Text="{Binding ProfileInitial}"
                                   Foreground="{DynamicResource BrushOnAccent}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="{Binding Username}"
                                   Foreground="{DynamicResource BrushText}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding VaultPath}"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   FontFamily="{StaticResource FontMono}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Multi-profile quick-select (visible only when 2+ profiles exist) -->
            <ItemsControl ItemsSource="{Binding AvailableProfiles}"
                          Visibility="{Binding HasMultipleProfiles, Converter={StaticResource BoolToVis}}"
                          Margin="0,0,0,12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource BtnSecondary}"
                                Content="{Binding}"
                                Margin="0,0,8,8"
                                Command="{Binding DataContext.SelectProfileCommand,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Username label + input -->
            <TextBlock Text="{DynamicResource Username}"
                       Style="{StaticResource FieldLabel}"
                       Margin="0,0,0,8"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,16"/>

            <!-- Master password label + input -->
            <TextBlock Text="{DynamicResource MasterPassword}"
                       Style="{StaticResource FieldLabel}"
                       Margin="0,0,0,8"/>
            <PasswordBox Style="{StaticResource PasswordInput}"
                         helpers:PasswordBoxHelper.BindSecurePassword="True"
                         helpers:PasswordBoxHelper.SecurePassword="{Binding SecurePassword, Mode=TwoWay}"/>

            <Button Style="{StaticResource BtnSecondary}"
                    Content="{DynamicResource ForgotPassword}"
                    HorizontalAlignment="Right"
                    Margin="0,4,0,0"
                    Command="{Binding ForgotPasswordCommand}"/>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource BrushDanger}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontSmall}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>

            <!-- Backoff / lockout status message -->
            <TextBlock Text="{Binding LockoutMessage}"
                       Foreground="{DynamicResource BrushWarning}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontSmall}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       Visibility="{Binding HasLockoutMessage, Converter={StaticResource BoolToVis}}"/>

            <!-- Unlock button — IsDefault makes Enter key trigger it from anywhere in the form -->
            <Button Content="{DynamicResource UnlockButton}"
                    Style="{StaticResource BtnPrimary}"
                    Command="{Binding UnlockCommand}"
                    IsDefault="True"
                    Margin="0,28,0,0"/>

            <!-- Divider -->
            <Border Height="1"
                    Background="{DynamicResource BrushStrokeSubtle}"
                    Margin="0,24"/>

            <!-- Create vault -->
            <Button Content="{DynamicResource CreateVault}"
                    Style="{StaticResource BtnSecondary}"
                    Command="{Binding NavigateRegisterCommand}"/>

            <!-- Exit application -->
            <Button Style="{StaticResource BtnSecondary}"
                    Margin="0,10,0,0"
                    Command="{Binding ExitCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="ExitToApp" Width="14" Height="14"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               VerticalAlignment="Center"/>
                    <TextBlock Text="Exit Application"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontBody}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
