<UserControl x:Class="IllyriaVault.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:IllyriaVault.Helpers">

    <!-- PHASE 1 STUB — replaced with full HTML-matched layout in Phase 2 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Minimal title bar (dragging handled by AuthWindow) -->
        <Border Grid.Row="0" Background="Transparent">
            <TextBlock Text="Illyria Vault"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontBody}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="16,0"/>
        </Border>

        <!-- Login form -->
        <StackPanel Grid.Row="1"
                    Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,40">

            <TextBlock Text="{DynamicResource LoginWelcome}"
                       Foreground="{DynamicResource BrushText}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontCardHead}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <TextBlock Text="{DynamicResource LoginSubtitle}"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontBody}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,24"/>

            <!-- Master password -->
            <TextBlock Text="{DynamicResource MasterPassword}"
                       Style="{StaticResource FieldLabel}"
                       Margin="0,0,0,8"/>

            <PasswordBox Style="{StaticResource PasswordInput}"
                         helpers:PasswordBoxHelper.BindPassword="True"
                         helpers:PasswordBoxHelper.BoundPassword="{Binding MasterPassword, Mode=TwoWay}"/>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource BrushDanger}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontSmall}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"/>

            <!-- Unlock button -->
            <Button Content="{DynamicResource UnlockButton}"
                    Style="{StaticResource BtnPrimary}"
                    Command="{Binding UnlockCommand}"
                    Margin="0,24,0,0"/>

            <!-- Divider -->
            <Border Height="1"
                    Background="{DynamicResource BrushStrokeSubtle}"
                    Margin="0,24"/>

            <!-- Create vault button -->
            <Button Content="{DynamicResource CreateVault}"
                    Style="{StaticResource BtnSecondary}"
                    Command="{Binding NavigateRegisterCommand}"/>

        </StackPanel>
    </Grid>
</UserControl>
