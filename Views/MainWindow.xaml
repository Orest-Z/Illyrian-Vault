<Window x:Class="IllyrianVault.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:conv="clr-namespace:IllyrianVault.Converters"
        Title="Illyrian Vault"
        Icon="/IllyrianVault.png"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Width="1320" Height="800"
        MinWidth="900" MinHeight="600">

    <Window.Resources>
        <conv:EqualityConverter      x:Key="EqConv"/>
        <conv:FavoriteIconConverter  x:Key="FavIcon"/>
        <conv:InverseBooleanConverter x:Key="InvBool"/>

        <!-- Nav RadioButton — looks like NavItem but uses RadioButton selection model -->
        <Style x:Key="NavRadioItem" TargetType="RadioButton">
            <Setter Property="Height"           Value="36"/>
            <Setter Property="Margin"           Value="8,1"/>
            <Setter Property="Padding"          Value="12,0"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"         Value="{StaticResource FontBody}"/>
            <Setter Property="FontWeight"       Value="Medium"/>
            <Setter Property="Foreground"       Value="{DynamicResource BrushTextSecondary}"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="GroupName"        Value="NavSections"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Indicator"
                                    Width="3" Height="16" CornerRadius="2"
                                    Background="{DynamicResource BrushAccent}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="-5,0,0,0" Visibility="Collapsed"/>
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Stretch"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BrushHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BrushSelected}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small section header label in sidebar nav -->
        <Style x:Key="NavSectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"    Value="{StaticResource FontLabel}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="{DynamicResource BrushTextTertiary}"/>
        </Style>

        <!-- Count badge pill used in nav items -->
        <Style x:Key="CountBadge" TargetType="Border">
            <Setter Property="Background"   Value="{DynamicResource BrushCard}"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding"      Value="7,2"/>
            <Setter Property="Margin"       Value="4,0,0,0"/>
        </Style>

        <!-- ── Sort ComboBox ─────────────────────────────────────────────────── -->
        <!-- Fully custom template: transparent-by-default pill that highlights on
             hover/open, with a themed popup that matches BrushCard + BrushStroke.  -->
        <Style x:Key="SortComboBox" TargetType="ComboBox">
            <Setter Property="Height"           Value="26"/>
            <Setter Property="MinWidth"         Value="130"/>
            <Setter Property="FontFamily"       Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"         Value="{StaticResource FontSmall}"/>
            <Setter Property="Foreground"       Value="{DynamicResource BrushText}"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource BrushStroke}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MaxDropDownHeight" Value="200"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="RootGrid">

                            <!-- ToggleButton owns the hit-test area and open/close.
                                 Its own template provides only the background + border;
                                 the ContentPresenter + chevron are layered on top. -->
                            <ToggleButton x:Name="TogglePart"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bg"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource BrushStroke}"
                                                BorderThickness="1"
                                                CornerRadius="6"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background"
                                                        Value="{DynamicResource BrushHover}"/>
                                                <Setter TargetName="Bg" Property="BorderBrush"
                                                        Value="{DynamicResource BrushStrokeStrong}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bg" Property="Background"
                                                        Value="{DynamicResource BrushSelected}"/>
                                                <Setter TargetName="Bg" Property="BorderBrush"
                                                        Value="{DynamicResource BrushAccent}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Selected-item text + chevron overlay (not hit-test-visible) -->
                            <Grid IsHitTestVisible="False" Margin="9,0,7,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                                <iconPacks:PackIconMaterial Grid.Column="1"
                                                            Kind="ChevronDown"
                                                            Width="10" Height="10"
                                                            Foreground="{DynamicResource BrushTextSecondary}"
                                                            VerticalAlignment="Center"
                                                            Margin="5,0,0,0"/>
                            </Grid>

                            <!-- Popup — AllowsTransparency needed for CornerRadius + shadow -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=RootGrid}"
                                   PopupAnimation="Fade"
                                   VerticalOffset="3">
                                <Border x:Name="DropBorder"
                                        MinWidth="{Binding ActualWidth, ElementName=RootGrid}"
                                        Background="{DynamicResource BrushCard}"
                                        BorderBrush="{DynamicResource BrushStroke}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="18"
                                                          ShadowDepth="5" Opacity="0.35"
                                                          Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer CanContentScroll="True"
                                                  MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- ComboBoxItem style — inlined so it shares the same DynamicResources -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Height"           Value="32"/>
                        <Setter Property="Padding"          Value="10,0"/>
                        <Setter Property="FontFamily"       Value="{StaticResource FontPrimary}"/>
                        <Setter Property="FontSize"         Value="{StaticResource FontSmall}"/>
                        <Setter Property="Foreground"       Value="{DynamicResource BrushText}"/>
                        <Setter Property="Background"       Value="Transparent"/>
                        <Setter Property="Cursor"           Value="Hand"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background"
                                                    Value="{DynamicResource BrushHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background"
                                                    Value="{DynamicResource BrushSelected}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True"/>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bg" Property="Background"
                                                    Value="{DynamicResource BrushAccentSoft}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer border: rounded corners + drop shadow (Win10 compatible) -->
    <Border x:Name="OuterBorder" Margin="20"
            Background="{DynamicResource BrushWindowGrad}"
            BorderBrush="{DynamicResource BrushStrokeSubtle}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="12"
                              Opacity="0.55" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ Title bar ════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Brand -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="22" Height="22" CornerRadius="6"
                                Background="{DynamicResource BrushAccent}">
                            <iconPacks:PackIconMaterial Kind="ShieldLock" Width="12" Height="12"
                                                        Foreground="{DynamicResource BrushOnAccent}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Illyrian Vault"
                                   Foreground="{DynamicResource BrushText}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="{StaticResource FontBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <Border Width="1" Height="14" Background="{DynamicResource BrushStroke}" Margin="14,0"/>
                        <TextBlock Text="{DynamicResource EncryptionLabel}"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Theme + Language seg controls (center) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Theme selector -->
                        <Border Background="{DynamicResource BrushElevated}"
                                BorderBrush="{DynamicResource BrushStroke}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="2" Height="28" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Style="{StaticResource SegButton}" Content="Light" GroupName="ThemeSel"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource EqConv}, ConverterParameter=Light}"/>
                                <RadioButton Style="{StaticResource SegButton}" Content="Dark" GroupName="ThemeSel"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource EqConv}, ConverterParameter=Dark}"/>
                                <RadioButton Style="{StaticResource SegButton}" Content="Kuq e Zi" GroupName="ThemeSel"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource EqConv}, ConverterParameter=Red}"/>
                            </StackPanel>
                        </Border>
                        <!-- Language selector -->
                        <Border Background="{DynamicResource BrushElevated}"
                                BorderBrush="{DynamicResource BrushStroke}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="2" Height="28">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Style="{StaticResource SegButton}" Content="EN" GroupName="LangSel"
                                             IsChecked="{Binding CurrentLanguage, Converter={StaticResource EqConv}, ConverterParameter=EN}"/>
                                <RadioButton Style="{StaticResource SegButton}" Content="SQ" GroupName="LangSel"
                                             IsChecked="{Binding CurrentLanguage, Converter={StaticResource EqConv}, ConverterParameter=SQ}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource BtnWinControl}" Click="MinimizeClick">
                            <iconPacks:PackIconMaterial Kind="Minus" Width="12" Height="12"/>
                        </Button>
                        <Button Style="{StaticResource BtnWinControl}" Click="MaximizeClick">
                            <iconPacks:PackIconMaterial x:Name="MaximizeIcon" Kind="Fullscreen" Width="11" Height="11"/>
                        </Button>
                        <Button Style="{StaticResource BtnClose}" Click="CloseClick">
                            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ 3-column body ═════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="248"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Column 0: Sidebar ──────────────────────────────────────── -->
                <Grid Grid.Column="0"
                      Background="{DynamicResource BrushSidebar}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <Border Grid.Row="0" Padding="8,8,8,4">
                        <Grid>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14"
                                                        Foreground="{DynamicResource BrushTextTertiary}"
                                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Margin="12,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable nav list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,4,0,8">

                            <!-- VAULT section -->
                            <TextBlock Text="{DynamicResource NavVault}"
                                       Style="{StaticResource NavSectionLabel}"
                                       Margin="20,12,20,6"/>

                            <RadioButton Style="{StaticResource NavRadioItem}"
                                         IsChecked="{Binding SelectedSection, Converter={StaticResource EqConv}, ConverterParameter=all}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="14" Height="14"
                                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource NavAll}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Style="{StaticResource CountBadge}">
                                        <TextBlock Text="{Binding TotalCount}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="{StaticResource FontTag}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavRadioItem}"
                                         IsChecked="{Binding SelectedSection, Converter={StaticResource EqConv}, ConverterParameter=favorites}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="Star" Width="14" Height="14"
                                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource NavFavorites}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Style="{StaticResource CountBadge}">
                                        <TextBlock Text="{Binding FavoriteCount}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="{StaticResource FontTag}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </RadioButton>

                            <!-- CATEGORIES section -->
                            <TextBlock Text="{DynamicResource NavCategories}"
                                       Style="{StaticResource NavSectionLabel}"
                                       Margin="20,12,20,6"/>

                            <RadioButton Style="{StaticResource NavRadioItem}"
                                         IsChecked="{Binding SelectedSection, Converter={StaticResource EqConv}, ConverterParameter=logins}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="LoginVariant" Width="14" Height="14"
                                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource NavLogins}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Style="{StaticResource CountBadge}">
                                        <TextBlock Text="{Binding LoginCount}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="{StaticResource FontTag}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavRadioItem}"
                                         IsChecked="{Binding SelectedSection, Converter={StaticResource EqConv}, ConverterParameter=notes}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="NoteText" Width="14" Height="14"
                                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource NavNotes}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Style="{StaticResource CountBadge}">
                                        <TextBlock Text="{Binding NoteCount}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="{StaticResource FontTag}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavRadioItem}"
                                         IsChecked="{Binding SelectedSection, Converter={StaticResource EqConv}, ConverterParameter=cards}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="CreditCard" Width="14" Height="14"
                                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource NavCards}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Style="{StaticResource CountBadge}">
                                        <TextBlock Text="{Binding CardCount}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="{StaticResource FontTag}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavRadioItem}"
                                         IsChecked="{Binding SelectedSection, Converter={StaticResource EqConv}, ConverterParameter=identities}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="AccountBox" Width="14" Height="14"
                                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource NavIdentities}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="2" Style="{StaticResource CountBadge}">
                                        <TextBlock Text="{Binding IdentityCount}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="{StaticResource FontTag}" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </RadioButton>

                            <!-- TOOLS section -->
                            <TextBlock Text="{DynamicResource NavTools}"
                                       Style="{StaticResource NavSectionLabel}"
                                       Margin="20,12,20,6"/>

                            <RadioButton Style="{StaticResource NavRadioItem}"
                                         IsChecked="{Binding SelectedSection, Converter={StaticResource EqConv}, ConverterParameter=generator}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="KeyVariant" Width="14" Height="14"
                                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{DynamicResource NavGenerator}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource NavRadioItem}"
                                         IsChecked="{Binding SelectedSection, Converter={StaticResource EqConv}, ConverterParameter=settings}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14"
                                                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{DynamicResource NavSettings}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Account badge -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource BrushElevated}"
                            BorderBrush="{DynamicResource BrushStrokeSubtle}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Margin="12,8,12,12"
                            Padding="10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Width="30" Height="30" CornerRadius="15"
                                        Background="{DynamicResource BrushAccent}">
                                    <TextBlock Text="{Binding ProfileInitial}"
                                               Foreground="{DynamicResource BrushOnAccent}"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name + label -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding ProfileUsername}"
                                               Foreground="{DynamicResource BrushText}"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{DynamicResource ProfileLocal}"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="12"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Lock button -->
                                <Button Grid.Column="2" Style="{StaticResource BtnIconSmall}"
                                        Command="{Binding LockCommand}"
                                        ToolTip="Lock vault">
                                    <iconPacks:PackIconMaterial Kind="Lock" Width="14" Height="14"/>
                                </Button>
                            </Grid>

                            <!-- Divider + Log Out button -->
                            <Border Height="1"
                                    Background="{DynamicResource BrushStrokeSubtle}"
                                    Margin="0,8,0,6"/>
                            <Button Style="{StaticResource BtnSecondary}"
                                    Content="{DynamicResource BtnLogOut}"
                                    Command="{Binding LogoutCommand}"
                                    Height="30"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Column 1: Entry list ──────────────────────────────────── -->
                <Grid Grid.Column="1"
                      Width="380"
                      Visibility="{Binding IsVaultSection, Converter={StaticResource BoolToVis}}"
                      Background="{DynamicResource BrushWindow}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Left stroke -->
                    <Border Grid.RowSpan="3"
                            BorderBrush="{DynamicResource BrushStrokeSubtle}"
                            BorderThickness="1,0,0,0"
                            IsHitTestVisible="False"/>

                    <!-- Header: title + count + New Entry button -->
                    <Grid Grid.Row="0" Margin="20,16,16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource NavAll}"
                                       Foreground="{DynamicResource BrushText}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSectionHead}"
                                       FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding FilteredEntries.Count}"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontFamily="{StaticResource FontPrimary}"
                                           FontSize="{StaticResource FontSmall}"/>
                                <TextBlock Text=" entries"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontFamily="{StaticResource FontPrimary}"
                                           FontSize="{StaticResource FontSmall}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource BtnPrimary}"
                                Content="{DynamicResource NewEntry}"
                                Command="{Binding RequestNewEntryCommand}"
                                Padding="12,0"/>
                    </Grid>

                    <!-- Sort row -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                Margin="20,0,20,8" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource SortedBy}"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="{StaticResource FontSmall}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Style="{StaticResource SortComboBox}"
                                  ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                                  Margin="6,0,0,0"/>
                    </StackPanel>

                    <!-- Entry list -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding FilteredEntries}"
                             SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                             Style="{StaticResource CleanListBox}"
                             Padding="12,0,12,12"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource EntryRow}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Initial tile -->
                                    <Border Width="36" Height="36" CornerRadius="8"
                                            Background="{DynamicResource BrushElevated}"
                                            BorderBrush="{DynamicResource BrushStroke}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding TileInitial}"
                                                   Foreground="{DynamicResource BrushAccent}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Title + username -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   Foreground="{DynamicResource BrushText}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DisplayUsername}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Favorite star -->
                                    <iconPacks:PackIconMaterial Grid.Column="2"
                                                               Kind="Star" Width="14" Height="14"
                                                               Foreground="{DynamicResource BrushWarning}"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- ── Column 2: Detail panel ────────────────────────────────── -->
                <Grid Grid.Column="2"
                      Background="{DynamicResource BrushWindow}">

                    <!-- Right stroke -->
                    <Border BorderBrush="{DynamicResource BrushStrokeSubtle}"
                            BorderThickness="1,0,0,0"
                            IsHitTestVisible="False"/>

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ShowEntryEmpty, Converter={StaticResource BoolToVis}}">
                        <iconPacks:PackIconMaterial Kind="ShieldLock"
                                                   Width="48" Height="48"
                                                   Foreground="{DynamicResource BrushAccentSoft}"
                                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Select an entry to view details"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="{StaticResource FontBody}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0"/>
                    </StackPanel>

                    <!-- Entry detail (scrollable) -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="32,28,32,28"
                                  Visibility="{Binding ShowEntryDetail, Converter={StaticResource BoolToVis}}">
                        <StackPanel>

                            <!-- ── Detail header ── -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Large initial tile -->
                                <Border Width="56" Height="56" CornerRadius="14"
                                        Background="{DynamicResource BrushElevated}"
                                        BorderBrush="{DynamicResource BrushStroke}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding SelectedEntry.TileInitial}"
                                               Foreground="{DynamicResource BrushAccent}"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontWeight="SemiBold" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Title + category chip + updated -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <!-- View mode title -->
                                    <TextBlock Text="{Binding SelectedEntry.Model.Title}"
                                               Foreground="{DynamicResource BrushText}"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="{StaticResource FontCardHead}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding SelectedEntry.IsNotEditing, Converter={StaticResource BoolToVis}}"/>
                                    <!-- Edit mode title -->
                                    <TextBox Style="{StaticResource InputBox}"
                                             Text="{Binding SelectedEntry.EditTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding SelectedEntry.IsEditing, Converter={StaticResource BoolToVis}}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Border Style="{StaticResource Chip}">
                                            <TextBlock Text="{Binding SelectedEntry.Model.Category}"
                                                       Foreground="{DynamicResource BrushAccent}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Foreground="{DynamicResource BrushTextTertiary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0">
                                            <Run Text="{DynamicResource UpdatedLabel}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding SelectedEntry.UpdatedFormatted, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Action icons: view mode (Edit + Favorite + Delete) -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Top"
                                            Visibility="{Binding SelectedEntry.IsNotEditing, Converter={StaticResource BoolToVis}}">
                                    <Button Style="{StaticResource BtnIcon}"
                                            Command="{Binding SelectedEntry.EditCommand}"
                                            ToolTip="Edit entry">
                                        <iconPacks:PackIconMaterial Kind="Pencil" Width="16" Height="16"
                                                                    Foreground="{DynamicResource BrushTextSecondary}"/>
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}"
                                            Command="{Binding ToggleFavoriteCommand}"
                                            ToolTip="Toggle favorite">
                                        <iconPacks:PackIconMaterial
                                            Kind="{Binding SelectedEntry.IsFavorite, Converter={StaticResource FavIcon}}"
                                            Width="16" Height="16"
                                            Foreground="{Binding SelectedEntry.IsFavoriteColor}"/>
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}"
                                            Command="{Binding DeleteEntryCommand}"
                                            ToolTip="Delete entry">
                                        <iconPacks:PackIconMaterial Kind="Delete" Width="16" Height="16"
                                                                    Foreground="{DynamicResource BrushDanger}"/>
                                    </Button>
                                </StackPanel>

                                <!-- Action icons: edit mode (Save + Cancel) -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Top"
                                            Visibility="{Binding SelectedEntry.IsEditing, Converter={StaticResource BoolToVis}}">
                                    <Button Style="{StaticResource BtnPrimary}"
                                            Content="Save"
                                            Command="{Binding SelectedEntry.SaveCommand}"
                                            Height="30" Padding="14,0"/>
                                    <Button Style="{StaticResource BtnSecondary}"
                                            Content="Cancel"
                                            Command="{Binding SelectedEntry.CancelEditCommand}"
                                            Height="30" Padding="12,0" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- ── View mode payload card ── -->
                            <Border Style="{StaticResource Card}" Margin="0,24,0,0"
                                    Visibility="{Binding SelectedEntry.IsNotEditing, Converter={StaticResource BoolToVis}}">
                                <ContentControl Content="{Binding SelectedEntry.CurrentPayload}"
                                                ContentTemplateSelector="{StaticResource PayloadViewSelector}"/>
                            </Border>

                            <!-- ── Edit mode payload card ── -->
                            <Border Style="{StaticResource Card}" Margin="0,24,0,0"
                                    Visibility="{Binding SelectedEntry.IsEditing, Converter={StaticResource BoolToVis}}">
                                <ContentControl Content="{Binding SelectedEntry.CurrentPayload}"
                                                ContentTemplateSelector="{StaticResource PayloadEditSelector}"/>
                            </Border>

                            <!-- ── Password Generator accordion (edit + Login only) ── -->
                            <Border Background="{DynamicResource BrushElevated}"
                                    BorderBrush="{DynamicResource BrushStroke}"
                                    BorderThickness="1" CornerRadius="8"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding SelectedEntry.IsEditingLogin, Converter={StaticResource BoolToVis}}">
                                <StackPanel DataContext="{Binding SelectedEntry}">
                                    <!-- Header toggle row -->
                                    <Button Style="{StaticResource BtnAccordion}"
                                            Command="{Binding Generator.ToggleExpandedCommand}"
                                            Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <iconPacks:PackIconMaterial Kind="KeyVariant"
                                                                        Width="14" Height="14"
                                                                        Foreground="{DynamicResource BrushAccent}"
                                                                        VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{DynamicResource NavGenerator}"
                                                       Foreground="{DynamicResource BrushText}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="{StaticResource FontBody}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"/>
                                            <iconPacks:PackIconMaterial Grid.Column="2"
                                                                        Kind="ChevronDown"
                                                                        Width="12" Height="12"
                                                                        Foreground="{DynamicResource BrushTextSecondary}"
                                                                        VerticalAlignment="Center"
                                                                        RenderTransformOrigin="0.5,0.5">
                                                <iconPacks:PackIconMaterial.Style>
                                                    <Style TargetType="iconPacks:PackIconMaterial">
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value><RotateTransform Angle="0"/></Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Generator.IsExpanded}" Value="True">
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value><RotateTransform Angle="180"/></Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </iconPacks:PackIconMaterial.Style>
                                            </iconPacks:PackIconMaterial>
                                        </Grid>
                                    </Button>

                                    <!-- Expandable body -->
                                    <StackPanel DataContext="{Binding Generator}"
                                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                Margin="12,0,12,12">
                                        <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}" Margin="0,0,0,12"/>

                                        <!-- Length -->
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock Text="{DynamicResource GenLength}"
                                                       Style="{StaticResource FieldLabel}"
                                                       VerticalAlignment="Center"/>
                                            <Border HorizontalAlignment="Right"
                                                    Background="{DynamicResource BrushCard}"
                                                    BorderBrush="{DynamicResource BrushStroke}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="10,3">
                                                <TextBlock Text="{Binding Length}"
                                                           Foreground="{DynamicResource BrushAccent}"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="{StaticResource FontBody}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                        <Slider Value="{Binding Length, Mode=TwoWay}"
                                                Minimum="8" Maximum="128"
                                                SmallChange="1" LargeChange="8"
                                                IsSnapToTickEnabled="True" TickFrequency="1"
                                                Margin="0,0,0,12"
                                                IsEnabled="{Binding UsePassphrase, Converter={StaticResource InvBool}}"/>

                                        <!-- Character set -->
                                        <Border Background="{DynamicResource BrushCard}"
                                                BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                                BorderThickness="1" CornerRadius="8"
                                                Padding="10,10" Margin="0,0,0,8"
                                                IsEnabled="{Binding UsePassphrase, Converter={StaticResource InvBool}}">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource GenCharset}"
                                                           Style="{StaticResource FieldLabel}"
                                                           Margin="0,0,0,10"/>
                                                <WrapPanel>
                                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                                              Content="{DynamicResource GenUppercase}"
                                                              IsChecked="{Binding UseUppercase, Mode=TwoWay}"
                                                              Margin="0,0,14,6"/>
                                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                                              Content="{DynamicResource GenLowercase}"
                                                              IsChecked="{Binding UseLowercase, Mode=TwoWay}"
                                                              Margin="0,0,14,6"/>
                                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                                              Content="{DynamicResource GenNumbers}"
                                                              IsChecked="{Binding UseNumbers, Mode=TwoWay}"
                                                              Margin="0,0,14,6"/>
                                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                                              Content="{DynamicResource GenSymbols}"
                                                              IsChecked="{Binding UseSymbols, Mode=TwoWay}"
                                                              Margin="0,0,0,6"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Passphrase mode -->
                                        <Border Background="{DynamicResource BrushCard}"
                                                BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                                BorderThickness="1" CornerRadius="8"
                                                Padding="10,10" Margin="0,0,0,10">
                                            <StackPanel>
                                                <CheckBox Style="{StaticResource VaultCheckBox}"
                                                          Content="{DynamicResource GenPassphrase}"
                                                          IsChecked="{Binding UsePassphrase, Mode=TwoWay}"/>
                                                <StackPanel Visibility="{Binding UsePassphrase, Converter={StaticResource BoolToVis}}"
                                                            Margin="0,10,0,0">
                                                    <Grid Margin="0,0,0,6">
                                                        <TextBlock Text="{DynamicResource GenWordCount}"
                                                                   Style="{StaticResource FieldLabel}"
                                                                   VerticalAlignment="Center"/>
                                                        <Border HorizontalAlignment="Right"
                                                                Background="{DynamicResource BrushElevated}"
                                                                BorderBrush="{DynamicResource BrushStroke}"
                                                                BorderThickness="1" CornerRadius="6"
                                                                Padding="10,3">
                                                            <TextBlock Text="{Binding WordCount}"
                                                                       Foreground="{DynamicResource BrushAccent}"
                                                                       FontFamily="{StaticResource FontMono}"
                                                                       FontSize="{StaticResource FontBody}"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                    <Slider Value="{Binding WordCount, Mode=TwoWay}"
                                                            Minimum="2" Maximum="10"
                                                            SmallChange="1" LargeChange="1"
                                                            IsSnapToTickEnabled="True" TickFrequency="1"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Generate button -->
                                        <Button Style="{StaticResource BtnPrimary}"
                                                Content="{DynamicResource GenGenerate}"
                                                Command="{Binding GenerateCommand}"
                                                Height="36" Margin="0,0,0,8"/>

                                        <!-- Result row: generated password + Copy + Use -->
                                        <Border Background="{DynamicResource BrushCard}"
                                                BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                                BorderThickness="1" CornerRadius="8"
                                                Padding="12,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding GeneratedPassword}"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource BrushText}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource BtnSecondary}"
                                                        Content="{DynamicResource GenCopy}"
                                                        Command="{Binding CopyToClipboardCommand}"
                                                        Height="30" Padding="10,0" Margin="8,0,0,0"/>
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource BtnPrimary}"
                                                        Content="{DynamicResource GenUsePassword}"
                                                        Command="{Binding UsePasswordCommand}"
                                                        Height="30" Padding="10,0" Margin="6,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── Password history card ── -->
                            <Border DataContext="{Binding SelectedEntry}"
                                    Background="{DynamicResource BrushCard}"
                                    BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,16,0,0">
                                <StackPanel>
                                    <!-- Header row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="8"
                                                Background="{DynamicResource BrushElevated}">
                                            <iconPacks:PackIconMaterial Kind="History"
                                                                        Width="16" Height="16"
                                                                        Foreground="{DynamicResource BrushTextSecondary}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Password History"
                                                       Foreground="{DynamicResource BrushText}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Previous passwords for this entry"
                                                       Foreground="{DynamicResource BrushTextTertiary}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource BtnSecondary}"
                                                Content="{DynamicResource ViewHistory}"
                                                Command="{Binding ToggleHistoryCommand}"
                                                Padding="12,0" Height="30"
                                                Margin="10,0,0,0"/>
                                    </Grid>

                                    <!-- Expandable history list -->
                                    <StackPanel Visibility="{Binding ShowHistory, Converter={StaticResource BoolToVis}}"
                                                Margin="0,12,0,0">
                                        <!-- Empty state -->
                                        <TextBlock Text="No password history yet."
                                                   Foreground="{DynamicResource BrushTextTertiary}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="12"
                                                   Visibility="{Binding ShowHistoryEmpty, Converter={StaticResource BoolToVis}}"
                                                   Margin="0,4,0,0"/>
                                        <!-- History items -->
                                        <ItemsControl ItemsSource="{Binding History}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource BrushElevated}"
                                                            BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                                            BorderThickness="1" CornerRadius="8"
                                                            Padding="12,10" Margin="0,4,0,0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Plaintext}"
                                                                       Foreground="{DynamicResource BrushText}"
                                                                       FontFamily="{StaticResource FontMono}"
                                                                       FontSize="12"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding DateLabel}"
                                                                       Foreground="{DynamicResource BrushTextTertiary}"
                                                                       FontFamily="{StaticResource FontPrimary}"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       Margin="16,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── Breach check card ── -->
                            <Border DataContext="{Binding SelectedEntry}"
                                    Background="{DynamicResource BrushCard}"
                                    BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,16,0,0">
                                <Grid>

                                    <!-- State: Not checked (default) -->
                                    <Grid Visibility="{Binding ShowBreachNotChecked,
                                              Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="8"
                                                Background="{DynamicResource BrushElevated}">
                                            <iconPacks:PackIconMaterial Kind="ShieldSearch"
                                                                        Width="16" Height="16"
                                                                        Foreground="{DynamicResource BrushTextSecondary}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Breach Check"
                                                       Foreground="{DynamicResource BrushText}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="k-anonymity · only 5 hash chars sent · password never leaves device"
                                                       Foreground="{DynamicResource BrushTextTertiary}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource BtnSecondary}"
                                                Content="Check for Breach"
                                                Command="{Binding CheckBreachCommand}"
                                                Padding="12,0" Height="30"
                                                Margin="10,0,0,0"/>
                                    </Grid>

                                    <!-- State: Checking (loading) -->
                                    <Grid Visibility="{Binding ShowBreachChecking,
                                              Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="8"
                                                Background="{DynamicResource BrushAccentSoft}">
                                            <iconPacks:PackIconMaterial Kind="ShieldSync"
                                                                        Width="16" Height="16"
                                                                        Foreground="{DynamicResource BrushAccent}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Checking breach database…"
                                                       Foreground="{DynamicResource BrushText}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Querying Have I Been Pwned via k-anonymity"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       FontFamily="{StaticResource FontPrimary}"
                                                       FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource BtnSecondary}"
                                                Content="Checking…"
                                                IsEnabled="False"
                                                Padding="12,0" Height="30"
                                                Margin="10,0,0,0"/>
                                    </Grid>

                                    <!-- State: Safe (not found in breaches) -->
                                    <Grid Visibility="{Binding ShowBreachSafe,
                                              Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="8"
                                                Background="{DynamicResource BrushSuccessSoft}">
                                            <iconPacks:PackIconMaterial Kind="ShieldCheck"
                                                                        Width="16" Height="16"
                                                                        Foreground="{DynamicResource BrushSuccess}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BreachMessage}"
                                                   Foreground="{DynamicResource BrushSuccess}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource BtnIconSmall}"
                                                Command="{Binding CheckBreachCommand}"
                                                ToolTip="Check again"
                                                Margin="8,0,0,0">
                                            <iconPacks:PackIconMaterial Kind="Refresh" Width="13" Height="13"/>
                                        </Button>
                                    </Grid>

                                    <!-- State: Breached (found in breach database) -->
                                    <Grid Visibility="{Binding ShowBreachBreached,
                                              Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="8"
                                                Background="{DynamicResource BrushDangerSoft}">
                                            <iconPacks:PackIconMaterial Kind="ShieldAlert"
                                                                        Width="16" Height="16"
                                                                        Foreground="{DynamicResource BrushDanger}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BreachMessage}"
                                                   Foreground="{DynamicResource BrushDanger}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource BtnIconSmall}"
                                                Command="{Binding CheckBreachCommand}"
                                                ToolTip="Check again"
                                                Margin="8,0,0,0">
                                            <iconPacks:PackIconMaterial Kind="Refresh" Width="13" Height="13"/>
                                        </Button>
                                    </Grid>

                                    <!-- State: Error (no internet or network failure) -->
                                    <Grid Visibility="{Binding ShowBreachError,
                                              Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="8"
                                                Background="{DynamicResource BrushWarningSoft}">
                                            <iconPacks:PackIconMaterial Kind="CloudOffOutline"
                                                                        Width="16" Height="16"
                                                                        Foreground="{DynamicResource BrushWarning}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BreachMessage}"
                                                   Foreground="{DynamicResource BrushText}"
                                                   FontFamily="{StaticResource FontPrimary}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource BtnIconSmall}"
                                                Command="{Binding CheckBreachCommand}"
                                                ToolTip="Retry"
                                                Margin="8,0,0,0">
                                            <iconPacks:PackIconMaterial Kind="Refresh" Width="13" Height="13"/>
                                        </Button>
                                    </Grid>

                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Password Generator Panel ──────────────────────── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="32,28,32,28"
                                  Visibility="{Binding IsGeneratorSection, Converter={StaticResource BoolToVis}}">
                        <StackPanel DataContext="{Binding Generator}">

                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="44" Height="44" CornerRadius="12"
                                        Background="{DynamicResource BrushAccentSoft}">
                                    <iconPacks:PackIconMaterial Kind="KeyVariant" Width="20" Height="20"
                                                                Foreground="{DynamicResource BrushAccent}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource GenTitle}"
                                           Foreground="{DynamicResource BrushText}"
                                           FontFamily="{StaticResource FontPrimary}"
                                           FontSize="{StaticResource FontSectionHead}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="14,0,0,0"/>
                            </StackPanel>

                            <!-- Length slider -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="{DynamicResource GenLength}"
                                                   Style="{StaticResource FieldLabel}"
                                                   VerticalAlignment="Center"/>
                                        <Border HorizontalAlignment="Right"
                                                Background="{DynamicResource BrushElevated}"
                                                BorderBrush="{DynamicResource BrushStroke}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10,3">
                                            <TextBlock Text="{Binding Length}"
                                                       Foreground="{DynamicResource BrushAccent}"
                                                       FontFamily="{StaticResource FontMono}"
                                                       FontSize="{StaticResource FontBody}"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                    <Slider Value="{Binding Length, Mode=TwoWay}"
                                            Minimum="8" Maximum="128"
                                            SmallChange="1" LargeChange="8"
                                            IsSnapToTickEnabled="True" TickFrequency="1"
                                            IsEnabled="{Binding UsePassphrase, Converter={StaticResource InvBool}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Character set options -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14"
                                    IsEnabled="{Binding UsePassphrase, Converter={StaticResource InvBool}}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource GenCharset}"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,14"/>
                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                              Content="{DynamicResource GenUppercase}"
                                              IsChecked="{Binding UseUppercase, Mode=TwoWay}"
                                              Margin="0,0,0,10"/>
                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                              Content="{DynamicResource GenLowercase}"
                                              IsChecked="{Binding UseLowercase, Mode=TwoWay}"
                                              Margin="0,0,0,10"/>
                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                              Content="{DynamicResource GenNumbers}"
                                              IsChecked="{Binding UseNumbers, Mode=TwoWay}"
                                              Margin="0,0,0,10"/>
                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                              Content="{DynamicResource GenSymbols}"
                                              IsChecked="{Binding UseSymbols, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- Passphrase mode -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <CheckBox Style="{StaticResource VaultCheckBox}"
                                              Content="{DynamicResource GenPassphrase}"
                                              IsChecked="{Binding UsePassphrase, Mode=TwoWay}"/>
                                    <StackPanel Visibility="{Binding UsePassphrase, Converter={StaticResource BoolToVis}}"
                                                Margin="0,14,0,0">
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="{DynamicResource GenWordCount}"
                                                       Style="{StaticResource FieldLabel}"
                                                       VerticalAlignment="Center"/>
                                            <Border HorizontalAlignment="Right"
                                                    Background="{DynamicResource BrushElevated}"
                                                    BorderBrush="{DynamicResource BrushStroke}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="10,3">
                                                <TextBlock Text="{Binding WordCount}"
                                                           Foreground="{DynamicResource BrushAccent}"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="{StaticResource FontBody}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                        <Slider Value="{Binding WordCount, Mode=TwoWay}"
                                                Minimum="2" Maximum="10"
                                                SmallChange="1" LargeChange="1"
                                                IsSnapToTickEnabled="True" TickFrequency="1"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Generate button -->
                            <Button Style="{StaticResource BtnPrimary}"
                                    Content="{DynamicResource GenGenerate}"
                                    Command="{Binding GenerateCommand}"
                                    Height="44"
                                    Margin="0,0,0,14"/>

                            <!-- Result card -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Border Background="{DynamicResource BrushElevated}"
                                            BorderBrush="{DynamicResource BrushStroke}"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="14,12" MinHeight="48"
                                            Margin="0,0,0,12">
                                        <TextBlock Text="{Binding GeneratedPassword}"
                                                   Foreground="{DynamicResource BrushText}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                    <Button Style="{StaticResource BtnSecondary}"
                                            Content="{DynamicResource GenCopy}"
                                            Command="{Binding CopyToClipboardCommand}"
                                            Height="38"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Settings Panel ─────────────────────────────────── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="32,28,32,28"
                                  Visibility="{Binding IsSettingsSection, Converter={StaticResource BoolToVis}}">
                        <StackPanel>

                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="44" Height="44" CornerRadius="12"
                                        Background="{DynamicResource BrushElevated}">
                                    <iconPacks:PackIconMaterial Kind="Cog" Width="20" Height="20"
                                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource SettingsTitle}"
                                           Foreground="{DynamicResource BrushText}"
                                           FontFamily="{StaticResource FontPrimary}"
                                           FontSize="{StaticResource FontSectionHead}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="14,0,0,0"/>
                            </StackPanel>

                            <!-- Appearance -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SettingsTheme}"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,14"/>
                                    <Border Background="{DynamicResource BrushElevated}"
                                            BorderBrush="{DynamicResource BrushStroke}"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="2" Height="36">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource SegButton}"
                                                         Content="{DynamicResource SettingsThemeLight}"
                                                         GroupName="SettingsThemeSel"
                                                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EqConv}, ConverterParameter=Light}"/>
                                            <RadioButton Style="{StaticResource SegButton}"
                                                         Content="{DynamicResource SettingsThemeDark}"
                                                         GroupName="SettingsThemeSel"
                                                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EqConv}, ConverterParameter=Dark}"/>
                                            <RadioButton Style="{StaticResource SegButton}"
                                                         Content="{DynamicResource SettingsThemeRed}"
                                                         GroupName="SettingsThemeSel"
                                                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EqConv}, ConverterParameter=Red}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Language -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SettingsLanguage}"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,14"/>
                                    <Border Background="{DynamicResource BrushElevated}"
                                            BorderBrush="{DynamicResource BrushStroke}"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="2" Height="36">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource SegButton}"
                                                         Content="English (EN)"
                                                         GroupName="SettingsLangSel"
                                                         IsChecked="{Binding CurrentLanguage, Converter={StaticResource EqConv}, ConverterParameter=EN}"/>
                                            <RadioButton Style="{StaticResource SegButton}"
                                                         Content="Shqip (SQ)"
                                                         GroupName="SettingsLangSel"
                                                         IsChecked="{Binding CurrentLanguage, Converter={StaticResource EqConv}, ConverterParameter=SQ}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Version -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource SettingsVersion}"
                                               Style="{StaticResource FieldLabel}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AppVersion}"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="{StaticResource FontBody}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Developer credit -->
                            <TextBlock Text="{DynamicResource SettingsDeveloper}"
                                       Foreground="{DynamicResource BrushTextTertiary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,0"/>

                        </StackPanel>
                    </ScrollViewer>

                </Grid>

            </Grid>

            <!-- ── Welcome overlay (fades out after login) ──────────────── -->
            <Grid x:Name="WelcomeOverlay"
                  Grid.RowSpan="2"
                  Panel.ZIndex="9999"
                  Background="{DynamicResource BrushWindow}"
                  IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="72" Height="72" CornerRadius="20"
                            Background="{DynamicResource BrushAccent}"
                            HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ColorAccent}"
                                              BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
                        </Border.Effect>
                        <iconPacks:PackIconMaterial Kind="ShieldLock"
                                                   Width="32" Height="32"
                                                   Foreground="{DynamicResource BrushOnAccent}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="WelcomeText"
                               Foreground="{DynamicResource BrushText}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="26" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,24,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
