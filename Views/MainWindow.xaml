<Window x:Class="IllyriaVault.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Illyria Vault"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Width="1320" Height="800"
        MinWidth="900" MinHeight="600">

    <!-- PHASE 1 STUB — replaced with full 3-column layout in Phase 2 -->
    <Border Margin="20"
            Background="{DynamicResource BrushWindowGrad}"
            BorderBrush="{DynamicResource BrushStrokeSubtle}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="12"
                              Opacity="0.55" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="22" Height="22" CornerRadius="6"
                                Background="{DynamicResource BrushAccent}">
                            <iconPacks:PackIconMaterial Kind="ShieldLock"
                                                        Width="12" Height="12"
                                                        Foreground="{DynamicResource BrushOnAccent}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Illyria Vault"
                                   Foreground="{DynamicResource BrushText}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="{StaticResource FontBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <Border Width="1" Height="14" Background="{DynamicResource BrushStroke}" Margin="14,0"/>
                        <TextBlock Text="{DynamicResource EncryptionLabel}"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource BtnWinControl}" Click="MinimizeClick">
                            <iconPacks:PackIconMaterial Kind="Minus" Width="12" Height="12"/>
                        </Button>
                        <Button Style="{StaticResource BtnWinControl}" Click="MaximizeClick">
                            <iconPacks:PackIconMaterial Kind="FullscreenExit" Width="11" Height="11"/>
                        </Button>
                        <Button Style="{StaticResource BtnClose}" Click="CloseClick">
                            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body placeholder — full layout arrives in Phase 2 -->
            <Border Grid.Row="1"
                    Background="{DynamicResource BrushWindow}"
                    CornerRadius="0,0,10,10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="ShieldLock"
                                               Width="48" Height="48"
                                               Foreground="{DynamicResource BrushAccent}"
                                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Illyria Vault"
                               Foreground="{DynamicResource BrushText}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontCardHead}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,8"/>
                    <TextBlock Text="Vault unlocked successfully. Full UI arrives in Phase 2."
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontBody}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
