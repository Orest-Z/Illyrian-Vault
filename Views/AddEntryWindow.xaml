<Window x:Class="IllyrianVault.Views.AddEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:helpers="clr-namespace:IllyrianVault.Helpers"
        xmlns:conv="clr-namespace:IllyrianVault.Converters"
        Title="New Entry"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="520" Height="620">

    <Window.Resources>
        <conv:EqualityConverter        x:Key="EqConv"/>
        <conv:InverseBooleanConverter  x:Key="InvBool"/>
    </Window.Resources>

    <!-- Outer shadow border — same pattern as main window -->
    <Border Margin="16"
            Background="{DynamicResource BrushWindow}"
            BorderBrush="{DynamicResource BrushStrokeSubtle}"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="10"
                              Opacity="0.5" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ─────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource BrushStrokeSubtle}"
                    BorderThickness="0,0,0,1"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0,4,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="8"
                                Background="{DynamicResource BrushAccentSoft}">
                            <iconPacks:PackIconMaterial Kind="Plus"
                                                        Width="14" Height="14"
                                                        Foreground="{DynamicResource BrushAccent}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="New Entry"
                                   Foreground="{DynamicResource BrushText}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="{StaticResource FontBody}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource BtnClose}"
                            Command="{Binding CancelCommand}">
                        <iconPacks:PackIconMaterial Kind="Close" Width="12" Height="12"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Form fields ───────────────────────────────────────── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,20,24,0">
                <StackPanel>

                    <!-- Title (required) -->
                    <TextBlock Text="{DynamicResource FieldTitle}"
                               Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <!-- Category -->
                    <TextBlock Text="{DynamicResource FieldCategory}"
                               Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource BrushElevated}"
                            BorderBrush="{DynamicResource BrushStroke}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="2" Height="34" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{StaticResource SegButton}" Content="Login"    GroupName="CatSel"
                                         IsChecked="{Binding SelectedCategory, Converter={StaticResource EqConv}, ConverterParameter=Login}"/>
                            <RadioButton Style="{StaticResource SegButton}" Content="Note"     GroupName="CatSel"
                                         IsChecked="{Binding SelectedCategory, Converter={StaticResource EqConv}, ConverterParameter=Note}"/>
                            <RadioButton Style="{StaticResource SegButton}" Content="Card"     GroupName="CatSel"
                                         IsChecked="{Binding SelectedCategory, Converter={StaticResource EqConv}, ConverterParameter=Card}"/>
                            <RadioButton Style="{StaticResource SegButton}" Content="Identity" GroupName="CatSel"
                                         IsChecked="{Binding SelectedCategory, Converter={StaticResource EqConv}, ConverterParameter=Identity}"/>
                        </StackPanel>
                    </Border>

                    <!-- Payload fields — routed by category via DataTemplateSelector -->
                    <ContentControl Content="{Binding CurrentPayload}"
                                    ContentTemplateSelector="{StaticResource PayloadEditSelector}"
                                    Margin="0,0,0,16"/>

                    <!-- ── Password Generator accordion (Login only) ── -->
                    <Grid Visibility="{Binding IsLoginCategory, Converter={StaticResource BoolToVis}}">
                    <Border Background="{DynamicResource BrushElevated}"
                            BorderBrush="{DynamicResource BrushStroke}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,16"
                            DataContext="{Binding Generator}">
                        <StackPanel>

                            <!-- Header toggle row -->
                            <Button Style="{StaticResource BtnAccordion}"
                                    Command="{Binding ToggleExpandedCommand}"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="KeyVariant"
                                                                Width="14" Height="14"
                                                                Foreground="{DynamicResource BrushAccent}"
                                                                VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{DynamicResource NavGenerator}"
                                               Foreground="{DynamicResource BrushText}"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="{StaticResource FontBody}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"/>
                                    <!-- Chevron rotates 180° when expanded -->
                                    <iconPacks:PackIconMaterial Grid.Column="2"
                                                                Kind="ChevronDown"
                                                                Width="12" Height="12"
                                                                Foreground="{DynamicResource BrushTextSecondary}"
                                                                VerticalAlignment="Center"
                                                                RenderTransformOrigin="0.5,0.5">
                                        <iconPacks:PackIconMaterial.Style>
                                            <Style TargetType="iconPacks:PackIconMaterial">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value><RotateTransform Angle="0"/></Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value><RotateTransform Angle="180"/></Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </iconPacks:PackIconMaterial.Style>
                                    </iconPacks:PackIconMaterial>
                                </Grid>
                            </Button>

                            <!-- Expandable body -->
                            <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                        Margin="12,0,12,12">

                                <Border Height="1" Background="{DynamicResource BrushStrokeSubtle}"
                                        Margin="0,0,0,12"/>

                                <!-- Length -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{DynamicResource GenLength}"
                                               Style="{StaticResource FieldLabel}"
                                               VerticalAlignment="Center"/>
                                    <Border HorizontalAlignment="Right"
                                            Background="{DynamicResource BrushCard}"
                                            BorderBrush="{DynamicResource BrushStroke}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="10,3">
                                        <TextBlock Text="{Binding Length}"
                                                   Foreground="{DynamicResource BrushAccent}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="{StaticResource FontBody}"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                                <Slider Value="{Binding Length, Mode=TwoWay}"
                                        Minimum="8" Maximum="128"
                                        SmallChange="1" LargeChange="8"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        Margin="0,0,0,12"
                                        IsEnabled="{Binding UsePassphrase, Converter={StaticResource InvBool}}"/>

                                <!-- Character set -->
                                <Border Background="{DynamicResource BrushCard}"
                                        BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="10,10" Margin="0,0,0,8"
                                        IsEnabled="{Binding UsePassphrase, Converter={StaticResource InvBool}}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource GenCharset}"
                                                   Style="{StaticResource FieldLabel}"
                                                   Margin="0,0,0,10"/>
                                        <WrapPanel>
                                            <CheckBox Style="{StaticResource VaultCheckBox}"
                                                      Content="{DynamicResource GenUppercase}"
                                                      IsChecked="{Binding UseUppercase, Mode=TwoWay}"
                                                      Margin="0,0,14,6"/>
                                            <CheckBox Style="{StaticResource VaultCheckBox}"
                                                      Content="{DynamicResource GenLowercase}"
                                                      IsChecked="{Binding UseLowercase, Mode=TwoWay}"
                                                      Margin="0,0,14,6"/>
                                            <CheckBox Style="{StaticResource VaultCheckBox}"
                                                      Content="{DynamicResource GenNumbers}"
                                                      IsChecked="{Binding UseNumbers, Mode=TwoWay}"
                                                      Margin="0,0,14,6"/>
                                            <CheckBox Style="{StaticResource VaultCheckBox}"
                                                      Content="{DynamicResource GenSymbols}"
                                                      IsChecked="{Binding UseSymbols, Mode=TwoWay}"
                                                      Margin="0,0,0,6"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Passphrase mode -->
                                <Border Background="{DynamicResource BrushCard}"
                                        BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="10,10" Margin="0,0,0,10">
                                    <StackPanel>
                                        <CheckBox Style="{StaticResource VaultCheckBox}"
                                                  Content="{DynamicResource GenPassphrase}"
                                                  IsChecked="{Binding UsePassphrase, Mode=TwoWay}"/>
                                        <StackPanel Visibility="{Binding UsePassphrase, Converter={StaticResource BoolToVis}}"
                                                    Margin="0,10,0,0">
                                            <Grid Margin="0,0,0,6">
                                                <TextBlock Text="{DynamicResource GenWordCount}"
                                                           Style="{StaticResource FieldLabel}"
                                                           VerticalAlignment="Center"/>
                                                <Border HorizontalAlignment="Right"
                                                        Background="{DynamicResource BrushElevated}"
                                                        BorderBrush="{DynamicResource BrushStroke}"
                                                        BorderThickness="1" CornerRadius="6"
                                                        Padding="10,3">
                                                    <TextBlock Text="{Binding WordCount}"
                                                               Foreground="{DynamicResource BrushAccent}"
                                                               FontFamily="{StaticResource FontMono}"
                                                               FontSize="{StaticResource FontBody}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                            <Slider Value="{Binding WordCount, Mode=TwoWay}"
                                                    Minimum="2" Maximum="10"
                                                    SmallChange="1" LargeChange="1"
                                                    IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Generate button -->
                                <Button Style="{StaticResource BtnPrimary}"
                                        Content="{DynamicResource GenGenerate}"
                                        Command="{Binding GenerateCommand}"
                                        Height="36"
                                        Margin="0,0,0,8"/>

                                <!-- Result row: generated password + Copy + Use -->
                                <Border Background="{DynamicResource BrushCard}"
                                        BorderBrush="{DynamicResource BrushStrokeSubtle}"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding GeneratedPassword}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource BrushText}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource BtnSecondary}"
                                                Content="{DynamicResource GenCopy}"
                                                Command="{Binding CopyToClipboardCommand}"
                                                Height="30" Padding="10,0" Margin="8,0,0,0"/>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource BtnPrimary}"
                                                Content="{DynamicResource GenUsePassword}"
                                                Command="{Binding UsePasswordCommand}"
                                                Height="30" Padding="10,0" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </StackPanel>
                    </Border>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer: Cancel + Save ──────────────────────────────── -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource BrushStrokeSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="24,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnSecondary}"
                            Content="{DynamicResource BtnCancel}"
                            Width="90" Margin="0,0,10,0"
                            Command="{Binding CancelCommand}"/>
                    <Button Style="{StaticResource BtnPrimary}"
                            Content="{DynamicResource BtnSaveEntry}"
                            Width="110"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
